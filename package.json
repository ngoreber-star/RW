{
  "name": "river-wall-erp",
  "version": "5.0.0",
  "description": "RIVER-WALL ERP V.5.0 - Desktop App",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist:dir": "electron-builder --win dir"
  },
  "build": {
    "appId": "com.riverwall.pro",
    "productName": "RIVER-WALL ERP V.5.0",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "app",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!dist/**"
        ]
      }
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "icon-512.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.0.0"
  }
}
